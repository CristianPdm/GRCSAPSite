# Copiar este archivo a ".env" en el servidor y completar los valores reales.
# El archivo ".env" NO se debe subir nunca a un repositorio ni compartir
# (es lo que protege la sesion de los usuarios del sitio).

# Clave secreta usada por Flask para firmar las cookies de sesion.
# Generarla una vez con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplazar-con-una-clave-larga-y-aleatoria

# Nombre de la empresa mostrado en la barra de navegación.
APP_NAME=Licencias & GRC · Mi Empresa

# Offset de zona horaria respecto a UTC (Argentina/Uruguay = -3).
APP_TIMEZONE_OFFSET_HOURS=-3


# Opcional: solo si se quiere mover la base SQLite a otra ruta del
# servidor en lugar de usar la carpeta instance/ por defecto.
# DATABASE_URL=sqlite:////var/lib/grc-app/grc_app.db
